{
  "name": "openwish",
  "private": true,
  "packageManager": "pnpm@9.5.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @openwish/web dev",
    "build": "pnpm --filter @openwish/web build",
    "typecheck": "pnpm --filter @openwish/shared typecheck && pnpm --filter @openwish/web typecheck",
    "test": "pnpm --filter @openwish/web test",
    "deploy": "pnpm --filter @openwish/web deploy"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
